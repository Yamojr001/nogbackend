extends layout

block content
  h2 Transaction Alert
  p Hello #{name},
  p A transaction has occurred on your wallet.
  div(style="background: #f7fafc; padding: 20px; border-radius: 6px; margin: 20px 0;")
    p(style="margin: 5px 0;") <strong>Type:</strong> #{type}
    p(style="margin: 5px 0;") <strong>Amount:</strong> #{currency} #{amount}
    p(style="margin: 5px 0;") <strong>Reference:</strong> #{reference}
    p(style="margin: 5px 0;") <strong>Date:</strong> #{date}
    p(style="margin: 5px 0;") <strong>Status:</strong> #{status}
  p Log in to your dashboard to view more details.
